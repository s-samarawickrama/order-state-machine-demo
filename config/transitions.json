{
  "version": "11.0",
  "description": "MediPick Simplified Order Engine implementing the 2-FSM architecture (ORDER_LIFECYCLE and PAYMENT) with linear prescription review and OTP verification.",
  "workflows": {

    "ORDER_LIFECYCLE": {
      "initial_state": "DRAFT",
      "terminal_states": ["COMPLETED", "CANCELLED", "CLOSED", "RESOLVED", "REJECTED"],
      "states": [
        { "id": "DRAFT", "display_name": "Draft", "color": "slate" },
        { "id": "SUBMITTED", "display_name": "Submitted", "color": "blue" },
        { "id": "PRESCRIPTION_VALIDATION", "display_name": "Prescription Validation", "color": "purple" },
        { "id": "AWAITING_PRESCRIPTION_UPLOAD", "display_name": "Awaiting Rx Re-upload", "color": "amber" },
        { "id": "WAITING_PHARMACY_CONFIRMATION", "display_name": "Waiting Pharmacy Confirmation", "color": "indigo" },
        { "id": "WAITING_CUSTOMER_CONFIRMATION", "display_name": "Waiting Customer Confirmation", "color": "orange" },
        { "id": "PREPARING", "display_name": "Preparing", "color": "pink" },
        { "id": "READY_FOR_PICKUP", "display_name": "Ready for Pickup", "color": "green" },
        { "id": "COMPLETED", "display_name": "Completed", "color": "emerald" },
        { "id": "CANCELLED", "display_name": "Cancelled", "color": "gray" },
        { "id": "CLOSED", "display_name": "Closed", "color": "zinc" },
        { "id": "ISSUE_REPORTED", "display_name": "Issue Reported", "color": "orange" },
        { "id": "UNDER_REVIEW", "display_name": "Under Review", "color": "blue" },
        { "id": "RESOLVED", "display_name": "Resolved", "color": "emerald" },
        { "id": "REJECTED", "display_name": "Claim Rejected", "color": "red" }
      ],
      "transitions": [
        {
          "id": "OL-001",
          "label": "Place Order",
          "current_state": "DRAFT",
          "event": "submit_order",
          "allowed_roles": ["CUSTOMER"],
          "next_state": "SUBMITTED",
          "actions": [
            { "type": "DISPATCH_EVENT", "event": "start_validation" },
            { "type": "DISPATCH_EVENT", "event": "skip_validation" }
          ]
        },
        {
          "id": "OL-001B",
          "label": "Discard Cart",
          "current_state": "DRAFT",
          "event": "discard_draft",
          "allowed_roles": ["CUSTOMER"],
          "next_state": "CANCELLED"
        },
        {
          "id": "OL-002A",
          "label": "Start Prescription Validation",
          "current_state": "SUBMITTED",
          "event": "start_validation",
          "allowed_roles": ["SYSTEM"],
          "conditions": [
            { "path": "order_type", "operator": "not_in", "value": ["OTC"] }
          ],
          "next_state": "PRESCRIPTION_VALIDATION"
        },
        {
          "id": "OL-002B",
          "label": "Skip Prescription Validation",
          "current_state": "SUBMITTED",
          "event": "skip_validation",
          "allowed_roles": ["SYSTEM"],
          "conditions": [
            { "path": "order_type", "operator": "equals", "value": "OTC" }
          ],
          "next_state": "WAITING_PHARMACY_CONFIRMATION"
        },
        {
          "id": "OL-003",
          "label": "Approve Prescription",
          "current_state": "PRESCRIPTION_VALIDATION",
          "event": "approve_prescription",
          "allowed_roles": ["PHARMACIST"],
          "next_state": "WAITING_PHARMACY_CONFIRMATION"
        },
        {
          "id": "OL-004",
          "label": "Reject Prescription",
          "current_state": "PRESCRIPTION_VALIDATION",
          "event": "reject_prescription",
          "allowed_roles": ["PHARMACIST"],
          "next_state": "CANCELLED"
        },
        {
          "id": "OL-005",
          "label": "Request Rx Re-upload",
          "current_state": "PRESCRIPTION_VALIDATION",
          "event": "request_clarification",
          "allowed_roles": ["PHARMACIST"],
          "next_state": "AWAITING_PRESCRIPTION_UPLOAD"
        },
        {
          "id": "OL-006",
          "label": "Re-upload Prescription",
          "current_state": "AWAITING_PRESCRIPTION_UPLOAD",
          "event": "reupload_prescription",
          "allowed_roles": ["CUSTOMER"],
          "next_state": "PRESCRIPTION_VALIDATION"
        },
        {
          "id": "OL-007",
          "label": "Pharmacy Confirms",
          "current_state": "WAITING_PHARMACY_CONFIRMATION",
          "event": "pharmacy_confirm",
          "allowed_roles": ["PHARMACY_STAFF", "PHARMACIST"],
          "next_state": "WAITING_CUSTOMER_CONFIRMATION"
        },
        {
          "id": "OL-008",
          "label": "Customer Confirms",
          "current_state": "WAITING_CUSTOMER_CONFIRMATION",
          "event": "customer_confirm",
          "allowed_roles": ["CUSTOMER"],
          "next_state": "PREPARING",
          "actions": [
            { "type": "CREATE_RESERVATION" },
            { "type": "DISPATCH_EVENT", "event": "pay_online" }
          ]
        },
        {
          "id": "OL-009",
          "label": "Start Preparing",
          "current_state": "PREPARING",
          "event": "start_preparing",
          "allowed_roles": ["PHARMACY_STAFF", "PHARMACIST"],
          "next_state": "PREPARING"
        },
        {
          "id": "OL-010",
          "label": "Mark Order Ready",
          "current_state": "PREPARING",
          "event": "mark_ready",
          "allowed_roles": ["PHARMACY_STAFF", "PHARMACIST"],
          "next_state": "READY_FOR_PICKUP",
          "actions": [
            { "type": "set_context", "path": "pickup.deadline", "value": "+48h" },
            { "type": "set_context", "path": "pickup.otp_generated", "value": true }
          ]
        },
        {
          "id": "OL-011",
          "label": "Complete Order (Verify OTP)",
          "current_state": "READY_FOR_PICKUP",
          "event": "complete_order",
          "allowed_roles": ["PHARMACY_STAFF", "PHARMACIST"],
          "conditions": [
            {
              "path": "pickup.otp_verified",
              "operator": "equals",
              "value": true
            },
            {
              "path": "states.PAYMENT",
              "operator": "equals",
              "value": "PAID"
            }
          ],
          "validation_errors": {
            "pickup.otp_verified": {
              "code": "OTP_REQUIRED",
              "severity": "BLOCKING",
              "message": "Pickup OTP code must be verified before completing the order."
            },
            "states.PAYMENT": {
              "code": "PAYMENT_REQUIRED",
              "severity": "BLOCKING",
              "message": "Order must be PAID before completion."
            }
          },
          "next_state": "COMPLETED",
          "actions": [
            { "type": "set_context", "path": "pickup.completed_at", "value": "now" }
          ]
        },
        {
          "id": "OL-012",
          "label": "Pickup Deadline Expired",
          "current_state": "READY_FOR_PICKUP",
          "event": "pickup_deadline_expired",
          "allowed_roles": ["SYSTEM"],
          "next_state": "CLOSED"
        },
        {
          "id": "OL-013",
          "label": "Cancel Order",
          "current_state": "SUBMITTED",
          "event": "cancel_order",
          "allowed_roles": ["CUSTOMER"],
          "next_state": "CANCELLED"
        },
        {
          "id": "OL-013B",
          "label": "Cancel Order",
          "current_state": "PRESCRIPTION_VALIDATION",
          "event": "cancel_order",
          "allowed_roles": ["CUSTOMER", "PHARMACY_STAFF", "PHARMACIST"],
          "next_state": "CANCELLED"
        },
        {
          "id": "OL-014",
          "label": "Cancel Order",
          "current_state": "WAITING_PHARMACY_CONFIRMATION",
          "event": "cancel_order",
          "allowed_roles": ["CUSTOMER", "PHARMACY_STAFF", "PHARMACIST"],
          "next_state": "CANCELLED"
        },
        {
          "id": "OL-015",
          "label": "Cancel Order",
          "current_state": "WAITING_CUSTOMER_CONFIRMATION",
          "event": "cancel_order",
          "allowed_roles": ["CUSTOMER"],
          "next_state": "CANCELLED"
        },
        {
          "id": "OL-016",
          "label": "Late Cancellation",
          "current_state": "PREPARING",
          "event": "cancel_order",
          "allowed_roles": ["CUSTOMER"],
          "next_state": "CANCELLED",
          "danger": true,
          "policy": {
            "warning": "Medicines already prepared. This is a late cancellation.",
            "track_metric": "late_cancellation",
            "late_cancel": true
          },
          "actions": [
            { "type": "RELEASE_RESERVATION" }
          ]
        },
        {
          "id": "OL-017",
          "label": "Late Cancellation (Ready)",
          "current_state": "READY_FOR_PICKUP",
          "event": "cancel_order",
          "allowed_roles": ["CUSTOMER"],
          "next_state": "CANCELLED",
          "danger": true,
          "policy": {
            "warning": "Medicines already packed. This is a late cancellation.",
            "track_metric": "late_cancellation",
            "late_cancel": true
          },
          "actions": [
            { "type": "RELEASE_RESERVATION" }
          ]
        },
        {
          "id": "OL-018",
          "label": "Report Issue",
          "current_state": "COMPLETED",
          "event": "report_issue",
          "allowed_roles": ["CUSTOMER"],
          "conditions": [
            {
              "path": "pickup.completed_at",
              "operator": "within_hours",
              "value": "issue_reporting_window_hours"
            }
          ],
          "validation_errors": {
            "pickup.completed_at": {
              "code": "REPORTING_WINDOW_EXPIRED",
              "severity": "BLOCKING",
              "message": "The reporting window for this order has expired."
            }
          },
          "next_state": "ISSUE_REPORTED"
        },
        {
          "id": "OL-019",
          "label": "Start Investigation",
          "current_state": "ISSUE_REPORTED",
          "event": "start_investigation",
          "allowed_roles": ["PHARMACY_STAFF", "PHARMACIST"],
          "next_state": "UNDER_REVIEW"
        },
        {
          "id": "OL-020",
          "label": "Resolve Issue",
          "current_state": "UNDER_REVIEW",
          "event": "resolve_issue",
          "allowed_roles": ["PHARMACIST", "ADMIN"],
          "next_state": "RESOLVED",
          "actions": [
            { "type": "CREATE_REPLACEMENT_ORDER" }
          ]
        },
        {
          "id": "OL-021",
          "label": "Reject Claim",
          "current_state": "UNDER_REVIEW",
          "event": "reject_claim",
          "allowed_roles": ["PHARMACIST", "ADMIN"],
          "next_state": "REJECTED"
        },
        {
          "id": "OL-022",
          "label": "Reopen Pickup",
          "current_state": "CLOSED",
          "event": "reopen_pickup",
          "allowed_roles": ["PHARMACY_STAFF", "PHARMACIST"],
          "next_state": "READY_FOR_PICKUP",
          "actions": [
            { "type": "set_context", "path": "pickup.deadline", "value": "+48h" },
            { "type": "set_context", "path": "pickup.otp_generated", "value": true }
          ]
        }
      ]
    },

    "PAYMENT": {
      "initial_state": "UNPAID",
      "terminal_states": ["PAID", "REFUNDED"],
      "states": [
        { "id": "UNPAID",   "display_name": "Unpaid",   "color": "slate" },
        { "id": "PAID",     "display_name": "Paid",     "color": "green" },
        { "id": "REFUNDED", "display_name": "Refunded", "color": "red" }
      ],
      "transitions": [
        {
          "id": "PM-001",
          "label": "Pay Online",
          "current_state": "UNPAID",
          "event": "pay_online",
          "allowed_roles": ["CUSTOMER", "SYSTEM"],
          "conditions": [
            {
              "path": "states.ORDER_LIFECYCLE",
              "operator": "in",
              "value": ["PREPARING", "READY_FOR_PICKUP"]
            }
          ],
          "validation_errors": {
            "states.ORDER_LIFECYCLE": {
              "code": "PAYMENT_NOT_ALLOWED_YET",
              "severity": "BLOCKING",
              "message": "Payment can only be made after stock is confirmed and checkout begins."
            }
          },
          "next_state": "PAID"
        },
        {
          "id": "PM-002",
          "label": "Refund Payment",
          "current_state": "PAID",
          "event": "refund_payment",
          "allowed_roles": ["SYSTEM"],
          "next_state": "REFUNDED"
        }
      ]
    }

  }
}